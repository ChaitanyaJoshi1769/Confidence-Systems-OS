# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT=10000

# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_LOG_LEVEL=debug

# Feature Flags
EXPO_PUBLIC_OFFLINE_FIRST_ENABLED=true
EXPO_PUBLIC_AUTO_SYNC_ENABLED=true
EXPO_PUBLIC_NOTIFICATIONS_ENABLED=true

# Sync Configuration
EXPO_PUBLIC_SYNC_INTERVAL_MS=300000
EXPO_PUBLIC_MAX_RETRY_ATTEMPTS=3
EXPO_PUBLIC_IMAGE_COMPRESSION_QUALITY=0.8

# Location Services
EXPO_PUBLIC_LOCATION_ENABLED=true
EXPO_PUBLIC_LOCATION_ACCURACY=Accuracy.High
