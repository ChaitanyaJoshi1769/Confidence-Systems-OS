# Application
NODE_ENV=development
PORT=3000
HOST=localhost
API_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=confidence_systems
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_MAX_CONNECTIONS=20
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USERNAME=

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=confidence-systems-evidence
AWS_S3_ENDPOINT=http://localhost:4566

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=confidence-api
KAFKA_GROUP_ID=confidence-api-group

# AI Services
AI_SERVICE_URL=http://localhost:3001
AI_SERVICE_TIMEOUT_MS=30000

# OpenAI / LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL_NAME=gpt-4

# OpenSearch
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3005

# Authentication
AUTH_SALT_ROUNDS=10
MFA_ENABLED=false
SESSION_TIMEOUT_MINUTES=60

# Observability
TRACING_ENABLED=false
METRICS_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_ENABLED=true

# Features
AI_VERIFICATION_ENABLED=true
COMPLIANCE_AUTOMATION_ENABLED=true
ANOMALY_DETECTION_ENABLED=true

# Email
EMAIL_PROVIDER=sendgrid
EMAIL_FROM_ADDRESS=noreply@confidence.systems
SENDGRID_API_KEY=

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
